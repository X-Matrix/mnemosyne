{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Mnemosyne",
    "version": "0.1.0",
    "identifier": "com.mnemosyne.app",
    "build": {
        "frontendDist": "../src"
    },
    "app": {
        "windows": [
            {
                "title": "Mnemosyne — 智能文件搜索",
                "width": 1280,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600,
                "resizable": true,
                "center": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": false,
        "targets": "all",
        "icon": []
    }
}